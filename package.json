{
	"name": "protfolio",
	"version": "0.0.1",
	"scripts": {
		"dev": "bunx vite dev",
		"build": "bunx vite build && bun run package",
		"preview": "bunx vite preview",
		"package": "bunx svelte-kit sync && bunx svelte-package && bunx publint",
		"prepublishOnly": "bun run package",
		"check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "bunx eslint . && bunx prettier --check .",
		"format": "bunx prettier --write .",
		"machine-translate": "inlang machine translate --project project.inlang",
		"paraglide": "paraglide-js build"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@inlang/cli": "^3.1.6",
		"@inlang/paraglide-js": "^2.13.2",
		"@inlang/sdk": "^2.7.0",
		"@portabletext/svelte": "^3.0.1",
		"@sanity/types": "^5.13.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/enhanced-img": "^0.9.3",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@sveltejs/vite-plugin-svelte-inspector": "^5.0.2",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/nodemailer": "^7.0.11",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@sanity/client": "^7.16.0",
		"@sanity/image-url": "^2.0.3",
		"@studio-freight/lenis": "^1.0.42",
		"@tailwindcss/vite": "^4.2.1",
		"@vercel/analytics": "^1.6.1",
		"nodemailer": "^7.0.13"
	}
}
